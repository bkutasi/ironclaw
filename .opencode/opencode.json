{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nvidia": {
      "name": "NVIDIA NIM API",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "headers": {
          "Authorization": "Bearer {env:NGC_KEY}"
        }
      },
      "models": {
        "step-3.5-flash": {
          "name": "Step 3.5 Flash",
          "id": "stepfun-ai/step-3.5-flash"
        }
      }
    },
    "llama.cpp": {
      "name": "llama-server (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:3000/v1"
      },
      "models": {
        "GLM-4.7-Flash": {
          "name": "GLM-4.7-Flash",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "GLM-4.7-Flash-Opus-Distill": {
          "name": "GLM-4.7-Flash-Opus-Distill",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "GPT-OSS-120B": {
          "name": "GPT-OSS-120B",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "Jan-V3": {
          "name": "Jan-V3",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "LFM-350M": {
          "name": "LFM-350M"
        },
        "LFM2.5-1.2B": {
          "name": "LFM2.5-1.2B"
        },
        "Nemotron-3-Nano": {
          "name": "Nemotron-3-Nano",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "Nemotron-3-Nano-Thinking": {
          "name": "Nemotron-3-Nano-Thinking",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "Qwen3-Coder-Next": {
          "name": "Qwen3-Coder-Next",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        }
      }
    }
  },
  "mode": {
    "build": {
      "prompt": "{file:/home/bkutasi/.config/opencode/prompt.txt}"
    }
  },
  "mcp": {
    "mem0": {
      "type": "local",
      "command": [
        "/media/nvme/virtualization/mem0/.venv/bin/python",
        "/media/nvme/virtualization/mem0/mcp_server/main.py"
      ],
      "environment": {
        "MEM0_API_URL": "http://localhost:8100"
      },
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "search-deep": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "search": {
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng"],
      "environment": {
        "SEARXNG_URL": "https://search.noemaai.com/"
      },
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "allow"
    },
    "edit": {
      "**/*.env*": "deny",
      "**/*.key": "deny",
      "**/*.secret": "deny",
      "node_modules/**": "deny",
      ".git/**": "deny",
      "*": "allow"
    }
  }
}
